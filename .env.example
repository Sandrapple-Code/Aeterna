# ==============================================================================
# Aeterna – The Career Operating System
# Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Application Environment
# Options: development, staging, production
APP_ENV=development
LOG_LEVEL=INFO

# Gemini API Key (Required for CareerForge Engine)
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Placeholder)
# SQLite is used as default for local development
DATABASE_URL=sqlite:///./aeterna.db

# Security & Encryption (Placeholder)
# Used for encrypting sensitive user sessions / tokens
SECRET_KEY=generate_a_secure_random_string_here
